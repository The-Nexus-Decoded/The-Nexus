#!/usr/bin/env bash
set -euo pipefail
# Usage: notify-critical.sh "Alert title" "Alert message"
# Sends urgent push notification via ntfy.sh
# Managed by Ansible — do not edit manually

# Input validation
if [ $# -lt 2 ]; then
    echo "Usage: $0 <title> <message>" >&2
    exit 1
fi

if [ -z "$1" ] || [ -z "$2" ]; then
    echo "Error: title and message must not be empty" >&2
    exit 1
fi

curl -s \
    -H "Title: $1" \
    -H "Priority: urgent" \
    -H "Tags: warning" \
    -d "$2" \
    {{ ntfy_server }}/{{ ntfy_topic }}
