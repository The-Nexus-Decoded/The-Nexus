{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "{{ discord_bot_token }}",
      "guilds": {
        "{{ discord_guild_id }}": {
          "slug": "{{ discord_guild_slug }}",
          "channels": {
            "{{ discord_channel_id }}": {
              "allow": true,
              "requireMention": {{ discord_require_mention | lower }}
            }
          }
        }
      },
      "historyLimit": {{ discord_history_limit }},
      "textChunkLimit": {{ discord_text_chunk_limit }}
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/openclaw/workspace"{% if openclaw_default_model is defined and openclaw_default_model %},
      "model": {{ openclaw_default_model | to_nice_json | indent(6, true) }}{% endif %}{% if openclaw_cli_backends is defined and openclaw_cli_backends %},
      "cliBackends": {{ openclaw_cli_backends | to_nice_json | indent(6, true) }}{% endif %}
    }
  },
  "logging": {
    "level": "info",
    "file": "/data/openclaw/logs/openclaw.log"
  }
}
