{
  "name": "mobile-gesture-feedback",
  "version": "1.0.0",
  "description": "Design tokens for mobile gesture feedback ring",
  "colors": {
    "ringFill": "#00D4FF",
    "error": "#FF4757",
    "committed": "#FFD700",
    "ringBackground": "#1A1A2E",
    "ringBackgroundOpacity": 0.4
  },
  "animation": {
    "timingFunction": "cubic-bezier(0.25, 0.1, 0.25, 1.0)",
    "ackDuration": 300,
    "commitDuration": 500
  },
  "latencyLabel": {
    "font": "SF Mono, system, monospace",
    "size": 11,
    "position": {
      "offsetY": 8,
      "anchor": "belowCenter"
    },
    "color": "#FFFFFF",
    "opacity": 0.7
  },
  "ui": {
    "zIndex": {
      "gameLayer": 0,
      "feedbackRing": 100,
      "reconnectUI": 200
    }
  },
  "packetLoss": {
    "bufferMs": 8,
    "thresholds": {
      "silent": 5000,
      "delayed": 15000,
      "unstable": 30000
    },
    "states": {
      "normal": { "indicator": null, "message": null },
      "delayed": { "indicator": "amber", "message": "Syncing..." },
      "unstable": { "indicator": "red", "message": "Connection unstable" },
      "reconnect": { "indicator": "red", "message": "Return to Spatial", "showUI": true }
    }
  },
  "reverseHandoff": {
    "gesture": "longPress",
    "direction": "vrToMobile"
  }
}
