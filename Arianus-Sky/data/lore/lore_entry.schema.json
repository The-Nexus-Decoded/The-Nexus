{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soul-drifter.game/lore-entry.schema.json",
  "title": "Lore Entry",
  "description": "A lore entry that can be discovered in the game",
  "type": "object",
  "required": ["id", "title", "text", "zone"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (e.g., 'zone1_wind_direction')"
    },
    "title": {
      "type": "string",
      "description": "Display title (e.g., 'Wind Direction')"
    },
    "zone": {
      "type": "integer",
      "description": "Zone number (1, 2, 3)"
    },
    "location": {
      "type": "string",
      "description": "In-game location where this is found"
    },
    "unlock_trigger": {
      "type": "string",
      "description": "Event/action that unlocks this entry"
    },
    "text": {
      "type": "string",
      "description": "The lore content"
    },
    "faction": {
      "type": "string",
      "enum": ["Aerian", "Sartan", "Durnai", "Patryn", "Naga", "Neutral"],
      "description": "Faction related to this entry"
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "Discovery tier (1=early, 3=late)"
    },
    "required_for_completion": {
      "type": "boolean",
      "description": "Whether this entry is required for zone completion"
    },
    "links": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Related lore entry IDs"
    }
  }
}
